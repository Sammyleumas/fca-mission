{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Registered user profile information",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "maxLength": 128
        },
        "displayName": {
          "type": "string",
          "maxLength": 100
        },
        "email": {
          "type": "string",
          "maxLength": 100
        },
        "photoURL": {
          "type": "string",
          "maxLength": 500
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["uid", "email"]
    },
    "Inquiry": {
      "title": "Contact Inquiry or Application",
      "description": "Admissions contact message or course application",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "maxLength": 128
        },
        "userId": {
          "type": "string",
          "maxLength": 128
        },
        "fullName": {
          "type": "string",
          "maxLength": 100
        },
        "email": {
          "type": "string",
          "maxLength": 100
        },
        "phone": {
          "type": "string",
          "maxLength": 30
        },
        "trackInterest": {
          "type": "string",
          "maxLength": 50
        },
        "selectedCourse": {
          "type": "string",
          "maxLength": 100
        },
        "message": {
          "type": "string",
          "maxLength": 1000
        },
        "status": {
          "type": "string",
          "enum": ["pending", "reviewed", "contacted"],
          "maxLength": 20
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["fullName", "email", "trackInterest", "message"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/UserProfile"
      },
      "description": "User profile collection"
    },
    "/inquiries/{inquiryId}": {
      "schema": {
        "$ref": "#/entities/Inquiry"
      },
      "description": "Course inquiries and student application submissions"
    }
  }
}
