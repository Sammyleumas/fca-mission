rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Connection test route
    match /test/connection {
      allow read: if true;
    }

    // Common Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Schema validation helpers
    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 100 &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 500));
    }

    function isValidInquiry(data) {
      return data.keys().hasAll(['fullName', 'email', 'trackInterest', 'message']) &&
             data.fullName is string && data.fullName.size() >= 2 && data.fullName.size() <= 100 &&
             data.email is string && data.email.size() >= 5 && data.email.size() <= 100 &&
             data.trackInterest is string && data.trackInterest.size() <= 50 &&
             data.message is string && data.message.size() >= 5 && data.message.size() <= 1000 &&
             (!('phone' in data) || (data.phone is string && data.phone.size() <= 30)) &&
             (!('selectedCourse' in data) || (data.selectedCourse is string && data.selectedCourse.size() <= 100)) &&
             (!('userId' in data) || (data.userId is string && data.userId.size() <= 128)) &&
             (!('status' in data) || (data.status is string && data.status.size() <= 20));
    }

    // User profiles
    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow create, update: if isOwner(userId) && isValidId(userId) && isValidUserProfile(incoming());
    }

    // Inquiries and course applications
    match /inquiries/{inquiryId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid && isValidId(inquiryId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isValidInquiry(incoming());
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && isValidInquiry(incoming());
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

  }
}
